# Environment template for langchain-examples
# Copy this file to .env and replace the placeholder values with your own credentials.

# LangChain / LangSmith observability
# Enables LangSmith tracing for LangChain runs.
LANGSMITH_TRACING=true
# Base URL for the LangSmith service.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# API key for LangSmith tracing and debugging.
LANGSMITH_API_KEY=your-langsmith-api-key
# Project name to associate traces with.
LANGSMITH_PROJECT=your-langsmith-project-name

# Core model provider credentials
# API key for OpenAI models.
OPENAI_API_KEY=your-openai-api-key
# API key for Anthropic models.
ANTHROPIC_API_KEY=your-anthropic-api-key
# API key for Groq models.
GROQ_API_KEY=your-groq-api-key
# API key for Mistral models.
MISTRAL_API_KEY=your-mistral-api-key
# API key for Google Gemini models.
GEMINI_API_KEY=your-gemini-api-key
# API key for Google generative services.
GOOGLE_API_KEY=your-google-api-key
# API key for DeepSeek models.
DEEPSEEK_API_KEY=your-deepseek-api-key
# API key for Phi models.
PHI_API_KEY=your-phi-api-key
# API key for Together AI models.
TOGETHER_API_KEY=your-together-api-key
# API key for SambaNova models.
SAMBANOVA_API_KEY=your-sambanova-api-key
# API key for AssemblyAI services.
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# OpenRouter configuration
# Base URL for OpenRouter-compatible model access.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# API key for OpenRouter.
OPENROUTER_API_KEY=your-openrouter-api-key
# Model identifier for OpenRouter.
OPENROUTER_MODEL=openai/gpt-4o-mini
# Maximum tokens for the default OpenRouter model.
OPENROUTER_MODEL_MAX_TOKENS=2000
# Model identifier for the mini OpenRouter model.
OPENROUTER_MODEL_5_MINI=openai/gpt-5-mini

# AI Credits configuration
# API key for the AI Credits provider.
AICREDITS_API_KEY=your-aicredits-api-key
# Base URL for the AI Credits provider.
AICREDITS_BASE_URL=https://aicredits.in/v1
# Model identifier for the AI Credits provider.
AICREDITS_MODEL=openai/gpt-4o-mini
# Maximum tokens for the AI Credits model.
AICREDITS_MODEL_MAX_TOKENS=2000
# Model identifier for the mini AI Credits model.
AICREDITS_MODEL_5_MINI=openai/gpt-5-mini

# Search, web, and document processing tools
# API key for Tavily search.
TAVILY_API_KEY=your-tavily-api-key
# API key for SerpAPI.
SERP_API_KEY=your-serp-api-key
# Google Programmable Search API key.
GOOGLE_PSE_API_KEY=your-google-pse-api-key
# Google Programmable Search engine ID.
GOOGLE_PSE_ENGINE_ID=your-google-pse-engine-id
# API key for Exa search.
EXA_API_KEY=your-exa-api-key
# API key for Jina AI services.
JINA_API_KEY=your-jina-api-key
# API key for Firecrawl.
FIRECRAWL_API_KEY=your-firecrawl-api-key
# API key for Unstructured document parsing.
UNSTRUCTURED_API_KEY=your-unstructured-api-key
# API key for NVIDIA services.
NVIDIA_API_KEY=your-nvidia-api-key
# API key for Hugging Face Hub.
HF_TOKEN=your-huggingface-token
# Token for Hugging Face Hub access.
HUGGINGFACEHUB_API_TOKEN=your-huggingfacehub-token
# API key for the financial datasets service.
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# Vector databases and graph stores
# URI for the Neo4j instance.
NEO4J_URI=bolt://localhost:7687
# Username for Neo4j.
NEO4J_USER=your-neo4j-username
# Password for Neo4j.
NEO4J_PASSWORD=your-neo4j-password
# Password for the AuraDB Neo4j service.
NEO4J_AURADB_PASSWORD=your-neo4j-auradb-password
# Pinecone environment name.
PINECONE_API_ENV=your-pinecone-environment
# Pinecone API key.
PINECONE_API_KEY=your-pinecone-api-key
# API key for Qdrant.
QDRANT_API_KEY=your-qdrant-api-key
# API key for Colivara.
COLIVARA_API_KEY=your-colivara-api-key

# Observability and monitoring
# API key for Phoenix tracing.
PHOENIX_API_KEY=your-phoenix-api-key
# Collector endpoint for Phoenix.
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-tenant
# API key for Weights & Biases.
WANDB_API_KEY=your-wandb-api-key
# API key for Guardian.
GUARDIAN_API_KEY=your-guardian-api-key
# API key for LangChain API access.
LANGCHAIN_API_KEY=your-langchain-api-key

# Cloud / authentication helpers
# API key for Google Cloud.
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key
# SSH authentication key for Git operations.
GIT_SSH_AUTH_KEY=your-git-ssh-key
# Username for BrightData.
BRIGHDATA_USERNAME=your-brightdata-username
# Password for BrightData.
BRIGHDATA_PASSWORD=your-brightdata-password
# API key for Ollama.
OLLAMA_API_KEY=your-ollama-api-key

# Azure OpenAI (optional)
# API key for Azure OpenAI.
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
# Endpoint for Azure OpenAI.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# API type for Azure OpenAI.
AZURE_OPENAI_API_TYPE=azure
# API version for Azure OpenAI.
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Deployment name for Azure OpenAI.
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
# Deployment name for embeddings.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=your-embedding-deployment
# Model name for embeddings.
AZURE_OPENAI_EMBEDDING_MODEL_NAME=text-embedding-ada-002
# Model version for Azure OpenAI embeddings.
AZURE_OPENAI_EMBEDDING_MODEL_VERSION=2023-05-15
